DATABASE_URL=sqlite+aiosqlite:///./firstfront.db
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173

# AI — Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Supabase (for production — https://supabase.com)
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_KEY=eyJ...

# File Storage — S3-compatible Backblaze B2 (Free Plan: 10GB storage)
# S3_ENDPOINT should be formatted as: https://s3.<region>.backblazeb2.com
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=firstfront-files
